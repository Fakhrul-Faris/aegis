# Copy to .env and fill in. .env is gitignored - secrets never enter git history.

# --- Mode override (paper | testnet | live). Defaults to config.yaml value. ---
# AEGIS_MODE=paper

# --- Telegram (P0.5 monitoring) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Hyperliquid (testnet first; never fund a key that lives on a dev machine carelessly) ---
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_PRIVATE_KEY=

# --- Kraken (read-only key first; trade permissions only at Strategy A go-live) ---
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- CoinGecko (free tier works without a key; demo key raises rate limits) ---
COINGECKO_API_KEY=
